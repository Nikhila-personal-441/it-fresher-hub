rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email — full read access to all collections
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'itfreshershub@gmail.com';
    }

    // Users can only read/write their own user doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Progress — users own their progress doc
    match /progress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Subscriptions — users can read their own; write on payment activation
    match /subscriptions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Payments — append-only for authenticated users
    match /payments/{paymentId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Certificates — users read/write their own
    match /certificates/{certId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    // Quiz attempts — users own their data
    match /quizAttempts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Login events — append-only
    match /loginEvents/{eventId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }
  }
}
